{
  "rabbit_version": "4.0.0",
  "users": [
    { "name": "guest", "password": "guest", "tags": ["administrator"] }
  ],
  "vhosts": [{ "name": "/" }],
  "permissions": [
    { "user": "guest", "vhost": "/", "configure": ".*", "write": ".*", "read": ".*" }
  ],
  "exchanges": [
    { "name": "user.events", "vhost": "/", "type": "topic", "durable": true, "auto_delete": false, "internal": false, "arguments": {} },
    { "name": "reservation.events", "vhost": "/", "type": "topic", "durable": true, "auto_delete": false, "internal": false, "arguments": {} },
    { "name": "ticket.events", "vhost": "/", "type": "topic", "durable": true, "auto_delete": false, "internal": false, "arguments": {} },
    { "name": "payment.events", "vhost": "/", "type": "topic", "durable": true, "auto_delete": false, "internal": false, "arguments": {} }
  ],
  "queues": [
    { "name": "user.registration.queue", "vhost": "/", "durable": true, "auto_delete": false, "arguments": {} },
    { "name": "reservation.update.queue", "vhost": "/", "durable": true, "auto_delete": false, "arguments": {} },
    { "name": "ticket.update.queue", "vhost": "/", "durable": true, "auto_delete": false, "arguments": {} },
    { "name": "payment.process.queue", "vhost": "/", "durable": true, "auto_delete": false, "arguments": {} }
  ],
  "bindings": [
    { "source": "user.events", "vhost": "/", "destination": "user.registration.queue", "destination_type": "queue", "routing_key": "user.registered", "arguments": {} },

    { "source": "reservation.events", "vhost": "/", "destination": "ticket.update.queue", "destination_type": "queue", "routing_key": "reservation.created", "arguments": {} },

    { "source": "ticket.events", "vhost": "/", "destination": "reservation.update.queue", "destination_type": "queue", "routing_key": "ticket.reserved", "arguments": {} },
    { "source": "ticket.events", "vhost": "/", "destination": "reservation.update.queue", "destination_type": "queue", "routing_key": "ticket.reservation.failed", "arguments": {} },
    { "source": "ticket.events", "vhost": "/", "destination": "payment.process.queue", "destination_type": "queue", "routing_key": "ticket.reserved", "arguments": {} },

    { "source": "payment.events", "vhost": "/", "destination": "reservation.update.queue", "destination_type": "queue", "routing_key": "payment.succeeded", "arguments": {} },
    { "source": "payment.events", "vhost": "/", "destination": "reservation.update.queue", "destination_type": "queue", "routing_key": "payment.failed", "arguments": {} },
    { "source": "payment.events", "vhost": "/", "destination": "ticket.update.queue", "destination_type": "queue", "routing_key": "payment.succeeded", "arguments": {} },
    { "source": "payment.events", "vhost": "/", "destination": "ticket.update.queue", "destination_type": "queue", "routing_key": "payment.failed", "arguments": {} }
  ]
}