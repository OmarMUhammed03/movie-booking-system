{
  "info": {
    "_postman_id": "movie-booking-saga-flow",
    "name": "Movie Booking Saga Flow",
    "description": "Postman collection to test the choreography-based saga pattern across reservation, show/ticket, and payment services via RabbitMQ events.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "movieId",
      "value": "",
      "type": "string"
    },
    {
      "key": "hallId",
      "value": "",
      "type": "string"
    },
    {
      "key": "showId",
      "value": "",
      "type": "string"
    },
    {
      "key": "ticketIds",
      "value": "[]",
      "type": "string"
    },
    {
      "key": "reservationId",
      "value": "",
      "type": "string"
    },
    {
      "key": "paymentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "stripeSessionId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. Setup - Prerequisites",
      "description": "Run these requests first to create the necessary data (user, movie, hall, show, tickets) before starting the saga.",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"phone\": \"+1234567890\",\n  \"password\": \"password123\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"userId\", pm.response.json().id || \"\")"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const token = pm.response.json().accessToken || pm.response.json().token;",
                  "pm.collectionVariables.set(\"authToken\", token);",
                  "pm.collectionVariables.set(\"userId\", pm.response.json().user.id || pm.response.json().userId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Movie",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Inception\",\n  \"description\": \"A thief who steals corporate secrets through the use of dream-sharing technology.\",\n  \"genre\": \"Sci-Fi\",\n  \"durationMinutes\": 148,\n  \"posterUrl\": \"https://example.com/inception.jpg\",\n  \"releaseDate\": \"2024-12-01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/movies",
              "host": ["{{baseUrl}}"],
              "path": ["api", "movies"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"movieId\", pm.response.json().id)"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Hall",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"IMAX Hall 1\",\n  \"totalSeats\": 50,\n  \"rowCount\": 5,\n  \"seatsPerRow\": 10,\n  \"screenType\": \"IMAX\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/halls",
              "host": ["{{baseUrl}}"],
              "path": ["api", "halls"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"hallId\", pm.response.json().id)"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Show",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movieId\": \"{{movieId}}\",\n  \"hallId\": \"{{hallId}}\",\n  \"startTime\": \"2024-12-01T18:00:00\",\n  \"endTime\": \"2024-12-01T20:30:00\",\n  \"price\": 15.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/shows",
              "host": ["{{baseUrl}}"],
              "path": ["api", "shows"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"showId\", pm.response.json().id)"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Tickets",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"showId\": \"{{showId}}\",\n    \"seatNumber\": \"A1\",\n    \"price\": 15.00\n  },\n  {\n    \"showId\": \"{{showId}}\",\n    \"seatNumber\": \"A2\",\n    \"price\": 15.00\n  }\n]"
            },
            "url": {
              "raw": "{{baseUrl}}/api/shows/tickets",
              "host": ["{{baseUrl}}"],
              "path": ["api", "shows", "tickets"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const ids = pm.response.json().map(t => t.id);",
                  "pm.collectionVariables.set(\"ticketIds\", JSON.stringify(ids));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1. Saga - Happy Path (Payment Succeeds)",
      "description": "Complete saga flow where ticket reservation succeeds and payment is completed successfully.",
      "item": [
        {
          "name": "1.1 Create Reservation (Saga Start)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"showId\": \"{{showId}}\",\n  \"ticketIds\": {{ticketIds}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reservations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reservations"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"reservationId\", pm.response.json().id);",
                  "console.log('Reservation created:', pm.response.json());"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Wait for Ticket Reservation (Async)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/reservations/{{reservationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reservations", "{{reservationId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const reservation = pm.response.json();",
                  "console.log('Reservation status:', reservation.status, 'Price:', reservation.totalPrice);",
                  "pm.test('Reservation has totalPrice set', () => {",
                  "    pm.expect(reservation.totalPrice).to.not.eql(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Create Payment Checkout Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservationId\": \"{{reservationId}}\",\n  \"userId\": \"{{userId}}\",\n  \"showId\": \"{{showId}}\",\n  \"ticketIds\": {{ticketIds}},\n  \"totalPrice\": 30.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "checkout"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"paymentId\", pm.response.json().id);",
                  "pm.collectionVariables.set(\"stripeSessionId\", pm.response.json().stripeSessionId);",
                  "console.log('Checkout session created:', pm.response.json());"
                ]
              }
            }
          ]
        },
        {
          "name": "1.4 Simulate Stripe Webhook (Payment Succeeded)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_test_webhook\",\n  \"object\": \"event\",\n  \"type\": \"checkout.session.completed\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"{{stripeSessionId}}\",\n      \"object\": \"checkout.session\",\n      \"payment_status\": \"paid\",\n      \"status\": \"complete\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/webhook",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "webhook"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('Webhook received:', pm.response.text());"
                ]
              }
            }
          ]
        },
        {
          "name": "1.5 Verify Reservation Confirmed",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/reservations/{{reservationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reservations", "{{reservationId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const reservation = pm.response.json();",
                  "console.log('Final reservation status:', reservation.status);",
                  "pm.test('Reservation is confirmed', () => {",
                  "    pm.expect(reservation.status).to.eql('CONFIRMED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.6 Verify Tickets are Booked",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/shows/tickets?showId={{showId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "shows", "tickets"],
              "query": [
                {
                  "key": "showId",
                  "value": "{{showId}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const tickets = pm.response.json();",
                  "console.log('Tickets:', tickets);",
                  "tickets.forEach(ticket => {",
                  "    pm.test(`Ticket ${ticket.seatNumber} is BOOKED`, () => {",
                  "        pm.expect(ticket.status).to.eql('BOOKED');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Saga - Failure Path (Payment Fails)",
      "description": "Saga flow where ticket reservation succeeds but payment fails, triggering compensation (tickets released, reservation cancelled).",
      "item": [
        {
          "name": "2.1 Create Reservation (Saga Start)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"showId\": \"{{showId}}\",\n  \"ticketIds\": {{ticketIds}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reservations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reservations"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"reservationId\", pm.response.json().id);",
                  "console.log('Reservation created:', pm.response.json());"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Create Payment Checkout Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservationId\": \"{{reservationId}}\",\n  \"userId\": \"{{userId}}\",\n  \"showId\": \"{{showId}}\",\n  \"ticketIds\": {{ticketIds}},\n  \"totalPrice\": 30.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "checkout"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"paymentId\", pm.response.json().id);",
                  "pm.collectionVariables.set(\"stripeSessionId\", pm.response.json().stripeSessionId);"
                ]
              }
            }
          ]
        },
        {
          "name": "2.3 Simulate Stripe Webhook (Payment Failed)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_test_webhook_failed\",\n  \"object\": \"event\",\n  \"type\": \"checkout.session.completed\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"{{stripeSessionId}}\",\n      \"object\": \"checkout.session\",\n      \"payment_status\": \"unpaid\",\n      \"status\": \"expired\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/webhook",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "webhook"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('Webhook received:', pm.response.text());"
                ]
              }
            }
          ]
        },
        {
          "name": "2.4 Verify Reservation Cancelled",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/reservations/{{reservationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reservations", "{{reservationId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const reservation = pm.response.json();",
                  "console.log('Final reservation status:', reservation.status);",
                  "pm.test('Reservation is cancelled', () => {",
                  "    pm.expect(reservation.status).to.eql('CANCELLED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.5 Verify Tickets Released",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/shows/tickets?showId={{showId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "shows", "tickets"],
              "query": [
                {
                  "key": "showId",
                  "value": "{{showId}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const tickets = pm.response.json();",
                  "tickets.forEach(ticket => {",
                  "    pm.test(`Ticket ${ticket.seatNumber} is AVAILABLE`, () => {",
                  "        pm.expect(ticket.status).to.eql('AVAILABLE');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Saga - Ticket Reservation Failure",
      "description": "Saga flow where ticket reservation fails immediately (e.g., seats already taken), triggering compensation.",
      "item": [
        {
          "name": "3.1 Create Reservation with Invalid Tickets",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"showId\": \"{{showId}}\",\n  \"ticketIds\": [\"00000000-0000-0000-0000-000000000000\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reservations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reservations"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"reservationId\", pm.response.json().id);",
                  "console.log('Reservation created (will fail):', pm.response.json());"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 Verify Reservation Cancelled",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/reservations/{{reservationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reservations", "{{reservationId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const reservation = pm.response.json();",
                  "console.log('Reservation status after failure:', reservation.status);",
                  "pm.test('Reservation is cancelled due to ticket failure', () => {",
                  "    pm.expect(reservation.status).to.eql('CANCELLED');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Verification - List Reservations",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/reservations/user/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "reservations", "user", "{{userId}}"]
        }
      }
    }
  ]
}
